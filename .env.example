# IBM watsonx.ai Credentials
# Copy this file to .env and fill in your values

# Your IBM Cloud API Key
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# Your watsonx.ai Project ID (found in watsonx.ai project settings)
WATSONX_PROJECT_ID=your_project_id_here

# watsonx.ai API URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model to use for resume analysis
# Options: ibm/granite-13b-instruct-v2, meta-llama/llama-3-70b-instruct
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2
